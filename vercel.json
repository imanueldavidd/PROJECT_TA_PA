{
  "services": [
    {
      "type": "web",
      "name": "frontend",
      "root": "frontend",
      "framework": "vite"
    },
    {
      "type": "web",
      "name": "backend",
      "root": "backend",
      "framework": "python"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}